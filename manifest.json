{
  "manifest_version": 3,
  "name": "GestureScroll — Hands-Free Shorts Navigator",
  "version": "1.0.0",
  "description": "Navigate YouTube Shorts and Instagram Reels with hand gestures. 100% on-device, zero data collection.",
  "author": "GestureScroll Contributors",

  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_title": "GestureScroll"
  },

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-scripts/content-main.js"],
      "run_at": "document_idle",
      "all_frames": false,
      "world": "MAIN"
    }
  ],

  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "camera"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "assets/mediapipe/*",
        "assets/icons/*",
        "content-scripts/content-main.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
